{%- comment -%}
  Gedeelde reviews in Trustpilot-stijl (homepage én productpagina, exact gelijk).
  Params (allemaal optioneel): eyebrow, heading, score_label, score, review_count,
  button_label, button_link, blocks (lijst met review-blokken).
  Zonder blocks tonen we 8 nette voorbeeldreviews. De kaarten schuiven automatisch
  van links naar rechts; 4 tegelijk in beeld; pauzeert bij hover/aanraken.
{%- endcomment -%}
{%- assign r_eyebrow = eyebrow | default: 'Beoordeeld door onze klanten' -%}
{%- assign r_heading = heading | default: 'Wat onze klanten zeggen' -%}
{%- assign r_label = score_label | default: 'Uitstekend' -%}
{%- assign r_score = score | default: '4,8' -%}
{%- assign r_count = review_count | default: '12' -%}
{%- capture tp_star -%}<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2l2.95 6.32 6.85.62-5.17 4.6 1.55 6.86L12 17.9l-6.13 3.3 1.55-6.86-5.17-4.6 6.85-.62z"/></svg>{%- endcapture -%}
{%- capture tp_check -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="#00b67a" stroke="none"/><polyline points="8 12.5 11 15.5 16 9" stroke="#fff"/></svg>{%- endcapture -%}

<section class="section reviews-tp">
  <div class="container container--wide">
    <div class="reviews-tp__head reveal">
      {%- if r_eyebrow != blank -%}<p class="eyebrow">{{ r_eyebrow }}</p>{%- endif -%}
      {%- if r_heading != blank -%}<h2 class="section-head__title">{{ r_heading }}</h2>{%- endif -%}
      <span class="reviews-tp__label">{{ r_label }}</span>
      <div class="tp-stars tp-stars--lg" role="img" aria-label="{{ r_score }} van 5 sterren">
        {%- for i in (1..5) -%}<span class="tp-star">{{ tp_star }}</span>{%- endfor -%}
      </div>
      <p class="reviews-tp__meta">
        {%- if r_score != blank -%}TrustScore <strong>{{ r_score }}</strong>{%- endif -%}
        {%- if r_count != blank -%} &middot; <strong>{{ r_count }}</strong> reviews{%- endif -%}
      </p>
    </div>
  </div>

  <div class="reviews-tp__track">
    <div class="reviews-tp__marquee">
    {%- for pass in (1..2) -%}
      {%- assign dupe = false -%}
      {%- if pass == 2 -%}{%- assign dupe = true -%}{%- endif -%}
      {%- if blocks != blank and blocks.size > 0 -%}
        {%- for block in blocks -%}
          {%- assign r = block.settings.rating | default: 5 -%}
          <article class="tp-card"{% if dupe %} aria-hidden="true"{% else %} {{ block.shopify_attributes }}{% endif %}>
            <div class="tp-stars" role="img" aria-label="{{ r }} van 5 sterren">{%- for i in (1..5) -%}<span class="tp-star{% if i > r %} tp-star--off{% endif %}">{{ tp_star }}</span>{%- endfor -%}</div>
            {%- if block.settings.title != blank -%}<h3 class="tp-card__title">{{ block.settings.title }}</h3>{%- endif -%}
            <p class="tp-card__body">{{ block.settings.text }}</p>
            <div class="tp-card__foot"><span class="tp-card__name">{{ block.settings.name }}</span>{%- if block.settings.date != blank -%}<span class="tp-card__date">{{ block.settings.date }}</span>{%- endif -%}</div>
            <p class="tp-card__verified">{{ tp_check }} Geverifieerd</p>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- assign demo = 'Snelle levering en top kwaliteit!|Binnen een dag geleverd en de kwaliteit is echt heerlijk. Zeker voor herhaling vatbaar.|Sandra V.|2 dagen geleden|5,Persoonlijk advies via de chat|Ik twijfelde over mijn maat en werd super vriendelijk geholpen. De jurk zit perfect.|Miranda K.|1 week geleden|5,Mooie collectie en fijne pasvorm|Elke week wat nieuws en het staat allemaal even mooi. Mijn favoriete webshop geworden.|Els D.|3 weken geleden|5,Altijd iets moois te vinden|Wekelijks nieuwe items en de kwaliteit blijft top. Ik bestel hier met een gerust hart.|Chantal B.|4 dagen geleden|5,Snel en netjes verpakt|Bestelling kwam supersnel en prachtig verpakt binnen. Echt een aanrader!|Priscilla M.|6 dagen geleden|5,Top klantenservice|Vraag gesteld en binnen no-time antwoord. Zo fijn dat je echt geholpen wordt.|Bianca T.|2 weken geleden|5,Kwaliteit voor een eerlijke prijs|De stoffen voelen luxe en de pasvorm is heerlijk. Ik krijg steeds complimenten.|Nadia H.|1 maand geleden|5,Mijn nieuwe favoriete winkel|Alles klopt: collectie service en levering. Ik kom zeker terug.|Wendy R.|5 dagen geleden|4' | split: ',' -%}
        {%- for d in demo -%}
          {%- assign parts = d | split: '|' -%}
          {%- assign rr = parts[4] | plus: 0 -%}
          <article class="tp-card"{% if dupe %} aria-hidden="true"{% endif %}>
            <div class="tp-stars" role="img" aria-label="{{ rr }} van 5 sterren">{%- for i in (1..5) -%}<span class="tp-star{% if i > rr %} tp-star--off{% endif %}">{{ tp_star }}</span>{%- endfor -%}</div>
            <h3 class="tp-card__title">{{ parts[0] }}</h3>
            <p class="tp-card__body">{{ parts[1] }}</p>
            <div class="tp-card__foot"><span class="tp-card__name">{{ parts[2] }}</span><span class="tp-card__date">{{ parts[3] }}</span></div>
            <p class="tp-card__verified">{{ tp_check }} Geverifieerd</p>
          </article>
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
    </div>
  </div>

  {%- if button_label != blank -%}
    <div class="container container--wide">
      <div class="reviews-tp__cta reveal">
        <a class="btn btn--outline" href="{{ button_link | default: '#' }}">{{ button_label }}</a>
      </div>
    </div>
  {%- endif -%}
</section>

{% style %}
  .reviews-tp { background: var(--bg); overflow: hidden; }
  .reviews-tp__head {
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
    text-align: center; margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .reviews-tp__label { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.4rem, 3vw, 2rem); letter-spacing: -0.01em; }
  .reviews-tp__meta { color: var(--muted); font-size: 0.92rem; }
  .reviews-tp__meta strong { color: var(--ink); font-weight: 700; }
  .tp-stars { display: inline-flex; gap: 4px; }
  .tp-star { width: 26px; height: 26px; background: #00b67a; color: #fff; display: inline-flex; align-items: center; justify-content: center; flex: none; }
  .tp-star--off { background: #dcdce6; }
  .tp-star svg { width: 17px; height: 17px; }
  .tp-stars--lg { gap: 5px; }
  .tp-stars--lg .tp-star { width: 34px; height: 34px; }
  .tp-stars--lg .tp-star svg { width: 22px; height: 22px; }
  .reviews-tp__track { overflow: hidden; margin: 0; padding: 0.25rem 0 0.75rem; }
  .reviews-tp__marquee { display: flex; width: max-content; padding-inline: var(--container-pad); animation: reviews-marquee 55s linear infinite; will-change: transform; }
  .reviews-tp:hover .reviews-tp__marquee { animation-play-state: paused; }
  .reviews-tp__marquee > .tp-card { flex: 0 0 clamp(258px, 26vw, 330px); margin-right: 1.25rem; }
  @keyframes reviews-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .reviews-tp__marquee { animation: none; } }
  .tp-card { background: var(--surface); border: 1px solid var(--ink); border-radius: var(--radius-lg); padding: clamp(1.25rem, 2.5vw, 1.75rem); display: flex; flex-direction: column; gap: 0.7rem; }
  .tp-card__title { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; line-height: 1.3; }
  .tp-card__body { color: var(--ink-soft); font-size: 0.92rem; line-height: 1.6; flex: 1; }
  .tp-card__foot { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.82rem; flex-wrap: wrap; }
  .tp-card__name { font-weight: 600; color: var(--ink); }
  .tp-card__date { color: var(--muted); }
  .tp-card__verified { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--muted); }
  .tp-card__verified svg { width: 16px; height: 16px; flex: none; }
  .reviews-tp__cta { text-align: center; margin-top: clamp(1.5rem, 3vw, 2.5rem); }
{% endstyle %}
