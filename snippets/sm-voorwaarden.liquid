{% style %}
  /* Pagina-header (gecentreerd) */
  .page-header {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) 0;
    text-align: center;
  }
  .page-header__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-top: var(--sp-0_75);
  }
  .page-header__meta {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: var(--sp-1);
  }

  /* Leeskolom: één smalle, rustige kolom voor de juridische tekst */
  .legal {
    max-width: 760px;
    margin-inline: auto;
  }
  .legal__lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    padding-bottom: var(--sp-2);
    margin-bottom: var(--sp-2);
    border-bottom: var(--border);
  }

  /* Genummerde artikelen */
  .legal-article + .legal-article {
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  .legal-article h2 {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    margin-bottom: var(--sp-1);
    scroll-margin-top: 96px;
  }
  .legal-article h3 {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin-top: var(--sp-1_5);
    margin-bottom: var(--sp-0_5);
  }

  /* Alinea's & lijsten: ruime regelafstand, prettig leesbaar */
  .legal p {
    color: var(--ink-soft);
    margin-bottom: var(--sp-1);
  }
  .legal p:last-child { margin-bottom: 0; }
  .legal ul,
  .legal ol {
    list-style: revert;
    padding-left: 1.4rem;
    margin-bottom: var(--sp-1);
    color: var(--ink-soft);
  }
  .legal li { margin-bottom: 0.4rem; }
  .legal li:last-child { margin-bottom: 0; }
  .legal address {
    font-style: normal;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  /* Slot-/contactblok onderaan de tekst */
  .legal__note {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--bg-alt);
    border: var(--border);
  }
  .legal__note p { margin-bottom: var(--sp-0_5); }
  .legal__note p:last-child { margin-bottom: 0; }
{% endstyle %}

<!-- BREADCRUMB -->
<div class="container">
  <nav class="breadcrumb" aria-label="Kruimelpad">
    <ul>
      <li><a href="/">Home</a></li>
      <li><span aria-current="page">Algemene voorwaarden</span></li>
    </ul>
  </nav>
</div>

<!-- PAGINA-HEADER: eyebrow + titel + laatst bijgewerkt -->
<section class="page-header">
  <div class="container">
    <p class="eyebrow reveal">Juridisch</p>
    <h1 class="page-header__title reveal" data-delay="1">Algemene voorwaarden</h1>
    <p class="page-header__meta reveal" data-delay="2">Laatst bijgewerkt: 22 juni 2026</p>
  </div>
</section>

<!-- LEESKOLOM: juridische tekst in genummerde artikelen -->
<section class="section section--tight">
