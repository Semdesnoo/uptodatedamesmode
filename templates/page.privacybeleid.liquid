<style>
  /* Pagina-header (gecentreerd) */
  .page-header {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) 0;
    text-align: center;
  }
  .page-header__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-top: var(--sp-0_75);
  }
  .page-header__meta {
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--sp-1);
  }

  /* Eén rustige leeskolom */
  .legal {
    max-width: 760px;
    margin-inline: auto;
  }
  .legal__intro {
    color: var(--ink-soft);
    font-size: 1.05rem;
    padding-bottom: var(--sp-2);
    margin-bottom: var(--sp-2);
    border-bottom: var(--border);
  }
  .legal section + section { margin-top: clamp(2rem, 4vw, 3rem); }
  .legal h2 {
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    margin-bottom: var(--sp-1);
  }
  .legal h2 .legal__num {
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    margin-right: 0.6rem;
    vertical-align: 0.12em;
  }
  .legal h3 {
    font-size: 1.1rem;
    margin-top: var(--sp-1_5);
    margin-bottom: var(--sp-0_5);
  }
  .legal p { color: var(--ink-soft); margin-bottom: var(--sp-1); }
  .legal p:last-child { margin-bottom: 0; }
  .legal ul {
    list-style: none;
    margin: 0 0 var(--sp-1);
    padding: 0;
  }
  .legal ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.55rem;
    color: var(--ink-soft);
  }
  .legal ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 6px;
    height: 1px;
    background: var(--accent);
  }
  .legal ul li:last-child { margin-bottom: 0; }
  .legal address {
    font-style: normal;
    color: var(--ink-soft);
    margin-bottom: var(--sp-1);
  }

  /* Compacte definitie-/gegevenstabel binnen de leeskolom */
  .legal__table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--sp-1) 0;
    font-size: 0.95rem;
  }
  .legal__table th,
  .legal__table td {
    text-align: left;
    vertical-align: top;
    padding: 0.7rem 0.9rem;
    border-bottom: var(--border);
    color: var(--ink-soft);
  }
  .legal__table th {
    width: 42%;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .legal__table,
    .legal__table tbody,
    .legal__table tr,
    .legal__table th,
    .legal__table td { display: block; width: 100%; }
    .legal__table th { border-bottom: none; padding-bottom: 0.2rem; }
    .legal__table td { padding-top: 0.2rem; }
  }
</style>

