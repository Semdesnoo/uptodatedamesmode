<section class="usp-bar">
  <div class="container container--wide">
    <div class="usp-bar__grid">
      {%- for block in section.blocks -%}
        <div class="usp" {{ block.shopify_attributes }}>
          {{ block.settings.icon_svg }}
          <div>
            <p class="usp__title">{{ block.settings.title }}</p>
            <p class="usp__sub">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "USP-balk",
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icoon (SVG-code)",
          "info": "Plak hier de volledige <svg>…</svg> code."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Verzekerde verzending"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtekst",
          "default": "Met Track & Trace"
        }
      ]
    }
  ],
