<section class="section{% if section.settings.beige_bg %} section--alt{% endif %}">
  <div class="container container--wide">
    <div class="editorial">
      <div class="editorial__media reveal">
        {%- if section.settings.image != blank -%}
          <figure class="media media--portrait">
            {%- render 'sm-picture', image: section.settings.image, image_mobile: section.settings.image_mobile, alt: section.settings.heading, loading: 'lazy', widths: '400, 600, 800, 1000', sizes: '(max-width: 749px) 90vw, 45vw' -%}
          </figure>
        {%- else -%}
          <div class="media media--portrait" data-label="{{ section.settings.placeholder_label | escape }}"></div>
        {%- endif -%}
      </div>
      <div class="editorial__body reveal" data-delay="1">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          {{ section.settings.text }}
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="btn btn--outline" href="{{ section.settings.button_link | default: '/pages/over-ons' }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Afbeelding — mobiel (optioneel)",
      "info": "Foto voor mobiel. Leeg = de desktopfoto wordt gebruikt."
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "Tekst op placeholder (zonder afbeelding)",
      "default": "Over ons"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop",
      "default": "Over ons"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Kop",
      "default": "Mode die up to date is, met persoonlijk advies."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Tekst",
      "default": "<p>Bij Up to Date Damesmode vind je elke week de nieuwste damesmode — met oog voor kwaliteit, pasvorm en een goed gevoel. Onze stylisten helpen je graag de perfecte outfit te vinden.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knoplabel",
      "default": "Lees ons verhaal"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knoplink"
    },
    {
      "type": "checkbox",
      "id": "beige_bg",
      "label": "Beige achtergrond",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Editorial"
    }
  ]
}
{% endschema %}
