<section class="section newsletter">
  <div class="container">
    <div class="newsletter__inner reveal">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}

      {% form 'customer', class: 'newsletter-form', novalidate: 'novalidate' %}
        {% if form.posted_successfully? %}
          <p class="newsletter__thanks">{{ section.settings.success_text }}</p>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="newsletter-email">Je e-mailadres</label>
          <input id="newsletter-email" type="email" name="contact[email]" value="{{ form.email }}" placeholder="Je e-mailadres" autocomplete="email" required>
          <button class="btn" type="submit">Inschrijven</button>
        {% endif %}
      {% endform %}

      {% if section.settings.disclaimer != blank %}
        <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nieuwsbrief",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop",
      "default": "Blijf op de hoogte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Word lid van de Up to Date Damesmode-club"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Tekst",
      "default": "Ontvang als eerste nieuwe collecties, stijltips en exclusieve aanbiedingen. En €10 korting op je eerste bestelling."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Je kunt je op elk moment uitschrijven."
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Bedanktekst na inschrijving",
      "default": "Welkom bij de club! Check je inbox voor je kortingscode."
    }
  ],
  "presets": [
    {
      "name": "Nieuwsbrief"
    }
  ]
}
{% endschema %}
