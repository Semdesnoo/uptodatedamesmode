{%- comment -%}
  TikTok-sectie (bestandsnaam blijft 'instagram' zodat de homepage-include
  {% section 'instagram' %} blijft werken). Toont automatisch afspelende clips
  (gedempt + loop = de enige manier waarop een browser autoplay toestaat).
  Geüploade video's spelen automatisch; zonder video valt een tegel terug op een
  afbeelding of nette placeholder. Elke tegel linkt naar TikTok.
{%- endcomment -%}
{%- assign tt_url = section.settings.tiktok_url | default: settings.social_tiktok | default: 'https://www.tiktok.com/@uptodatedamesmode' -%}

<section class="section section--tight">
  <div class="container container--wide">
    <div class="section-head section-head--center reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-head__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="tt-grid reveal" data-tt-grid>
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign clip_link = block.settings.link | default: tt_url -%}
          <div class="tt-tile" {{ block.shopify_attributes }}>
            <a class="tt-tile__link" href="{{ clip_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ block.settings.label | default: 'Bekijk op TikTok' | escape }}">
              {%- if block.settings.video != blank -%}
                {%- assign clip = block.settings.video -%}
                <video class="tt-tile__video" autoplay muted loop playsinline preload="metadata"{% if clip.preview_image != blank %} poster="{{ clip.preview_image | image_url: width: 500 }}"{% endif %} aria-label="{{ block.settings.label | default: 'TikTok-clip' | escape }}">
                  {%- for source in clip.sources -%}
                    {%- if source.mime_type == 'video/mp4' -%}
                      <source src="{{ source.url }}" type="video/mp4">
                    {%- endif -%}
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.image != blank -%}
                <figure class="media tt-tile__media">
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.label, widths: '300, 400, 600', sizes: '(max-width: 749px) 62vw, 19vw' }}
                </figure>
              {%- else -%}
                <div class="media tt-tile__media" data-label="{{ block.settings.label | default: '@uptodatedamesmode' | escape }}"></div>
              {%- endif -%}
              <span class="tt-tile__badge" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c.32 2.06 1.47 3.3 3.5 3.45v2.42c-1.18.12-2.21-.27-3.41-.99l-.01 5.62c0 3.57-2.6 6.25-6.04 6.25-3.13 0-5.54-2.45-5.54-5.5 0-3.27 2.65-5.62 6.04-5.27v2.65c-.4-.13-.83-.2-1.27-.2-1.39 0-2.43 1.03-2.43 2.41 0 1.46 1.08 2.49 2.5 2.49 1.5 0 2.62-1.18 2.62-2.92V3h3.04z"/></svg>
              </span>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Nog geen clips toegevoegd: nette placeholders zodat de sectie niet leeg is. {%- endcomment -%}
        {%- assign demo_labels = 'Nieuw binnen,Styling,In de winkel,Behind the scenes,Jouw look' | split: ',' -%}
        {%- for label in demo_labels -%}
          <div class="tt-tile">
            <a class="tt-tile__link" href="{{ tt_url }}" target="_blank" rel="noopener noreferrer" aria-label="Bekijk @uptodatedamesmode op TikTok">
              <div class="media tt-tile__media" data-label="{{ label }}"></div>
              <span class="tt-tile__badge" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c.32 2.06 1.47 3.3 3.5 3.45v2.42c-1.18.12-2.21-.27-3.41-.99l-.01 5.62c0 3.57-2.6 6.25-6.04 6.25-3.13 0-5.54-2.45-5.54-5.5 0-3.27 2.65-5.62 6.04-5.27v2.65c-.4-.13-.83-.2-1.27-.2-1.39 0-2.43 1.03-2.43 2.41 0 1.46 1.08 2.49 2.5 2.49 1.5 0 2.62-1.18 2.62-2.92V3h3.04z"/></svg>
              </span>
            </a>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="tt-cta reveal">
      <a class="btn btn--outline" href="{{ tt_url }}" target="_blank" rel="noopener noreferrer">{{ section.settings.button_label | default: 'Volg @uptodatedamesmode' }}</a>
    </div>
  </div>
</section>

{% style %}
  .tt-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(0.5rem, 1.5vw, 1rem);
    margin-top: var(--sp-1);
  }
  .tt-tile { position: relative; min-width: 0; }
  .tt-tile__link {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid var(--ink);
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
  }
  .tt-tile__video,
  .tt-tile__media,
  .tt-tile__link .media {
    width: 100%;
    height: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    display: block;
  }
  .tt-tile__video,
  .tt-tile__media img,
  .tt-tile__media { transition: transform 0.6s ease; }
  .tt-tile__link:hover .tt-tile__video,
  .tt-tile__link:hover .tt-tile__media img,
  .tt-tile__link:hover .tt-tile__media { transform: scale(1.04); }
  .tt-tile__badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: rgba(20, 18, 16, 0.55);
    border-radius: 999px;
    pointer-events: none;
  }
  .tt-tile__badge svg { width: 15px; height: 15px; }
  .tt-cta { text-align: center; margin-top: var(--sp-2); }

  @media (max-width: 1100px) {
    .tt-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 749px) {
    .tt-grid {
      grid-auto-flow: column;
      grid-template-columns: none;
      grid-auto-columns: 62%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.25rem;
    }
    .tt-grid::-webkit-scrollbar { display: none; }
    .tt-tile { scroll-snap-align: start; }
  }
  @media (prefers-reduced-motion: reduce) {
    .tt-tile__video,
    .tt-tile__media img,
    .tt-tile__media { transition: none; }
  }
{% endstyle %}

<script>
  (function () {
    var grid = document.querySelector("[data-tt-grid]");
    if (!grid) return;
    var vids = grid.querySelectorAll("video");
    if (!vids.length) return;

    var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      vids.forEach(function (v) { v.removeAttribute("autoplay"); try { v.pause(); } catch (e) {} });
      return;
    }

    /* Speel alleen zichtbare video's af (zuinig met data en rekenkracht). */
    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          var v = entry.target;
          if (entry.isIntersecting) {
            var p = v.play();
            if (p && p.catch) p.catch(function () {});
          } else {
            try { v.pause(); } catch (e) {}
          }
        });
      }, { threshold: 0.4 });
      vids.forEach(function (v) { io.observe(v); });
    }
  })();
</script>

{% schema %}
{
  "name": "TikTok",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop",
      "default": "Volg ons"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Kop",
      "default": "@uptodatedamesmode op TikTok"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtekst",
      "default": ""
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok-link (leeg = uit instellingen)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knoplabel",
      "default": "Volg @uptodatedamesmode"
    }
  ],
  "blocks": [
    {
      "type": "clip",
      "name": "TikTok-clip",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload een korte clip (staand, 9:16). Deze speelt automatisch en gedempt af — de enige manier waarop autoplay is toegestaan."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Afbeelding (als er geen video is gekozen)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link naar de TikTok-video (optioneel)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label / placeholder-tekst",
          "default": "@uptodatedamesmode"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TikTok",
      "blocks": [
        { "type": "clip", "settings": { "label": "Nieuw binnen" } },
        { "type": "clip", "settings": { "label": "Styling" } },
        { "type": "clip", "settings": { "label": "In de winkel" } },
        { "type": "clip", "settings": { "label": "Behind the scenes" } },
        { "type": "clip", "settings": { "label": "Jouw look" } }
      ]
    }
  ]
}
{% endschema %}
