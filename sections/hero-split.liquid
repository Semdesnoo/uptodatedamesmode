{%- comment -%}
  Split-hero: één grote foto over de volle breedte met een grote titel eroverheen.
  De foto kan naar een collectie/pagina linken. Zonder foto tonen we een nette
  placeholder zodat de sectie nooit leeg is.
{%- endcomment -%}
{%- assign height_class = 'hero-split--' | append: section.settings.height -%}

<section class="hero-split {{ height_class }}">
  <div class="hero-split__panes">
    {%- if section.settings.link != blank -%}
      <a class="hero-split__pane" href="{{ section.settings.link }}" aria-label="{{ section.settings.image_alt | default: 'Ontdek meer' | escape }}">
    {%- else -%}
      <div class="hero-split__pane">
    {%- endif -%}
      {%- if section.settings.image != blank -%}
        <figure class="media media--full">
          {%- render 'sm-picture', image: section.settings.image, image_mobile: section.settings.image_mobile, alt: section.settings.image_alt, loading: 'eager', fetchpriority: 'high', widths: '600, 900, 1200, 1600, 2000, 2400', sizes: '100vw' -%}
        </figure>
      {%- else -%}
        <div class="media media--full" data-label="{{ section.settings.image_alt | default: 'Sfeerbeeld' | escape }}"></div>
      {%- endif -%}
    {%- if section.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
  </div>

  <div class="hero-split__overlay"></div>

  <div class="hero-split__content" data-align="{{ section.settings.text_position }}">
    <div class="container container--wide hero-split__inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow hero-split__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-split__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="hero-split__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
        <div class="hero-split__actions">
          {%- if section.settings.button_1_label != blank -%}
            <a class="btn btn--light" href="{{ section.settings.button_1_link | default: '#' }}">{{ section.settings.button_1_label }}</a>
          {%- endif -%}
          {%- if section.settings.button_2_label != blank -%}
            <a class="btn btn--outline-light" href="{{ section.settings.button_2_link | default: '#' }}">{{ section.settings.button_2_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  .hero-split { position: relative; overflow: hidden; }
  .hero-split__panes {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .hero-split__pane { position: relative; display: block; overflow: hidden; }
  .hero-split__pane .media {
    height: 100%;
    aspect-ratio: auto;
    min-height: inherit;
  }
  /* Hoogte-varianten */
  .hero-split--medium .hero-split__pane { min-height: 62vh; }
  .hero-split--large  .hero-split__pane { min-height: 78vh; }
  .hero-split--full   .hero-split__pane { min-height: calc(100vh - 76px); }

  .hero-split__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg,
      rgba(28, 26, 23, 0.18) 0%,
      rgba(28, 26, 23, 0.04) 42%,
      rgba(28, 26, 23, 0.48) 100%);
    pointer-events: none;
  }
  .hero-split__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    pointer-events: none;      /* klikken gaan door naar de foto-helften eronder */
  }
  .hero-split__content[data-align="bottom"] { align-items: flex-end; padding-bottom: clamp(2.5rem, 6vw, 5rem); }
  .hero-split__content[data-align="center"] { align-items: center; }
  .hero-split__inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: var(--bg);
  }
  .hero-split__eyebrow { color: var(--bg); opacity: 0.92; }
  .hero-split__title {
    color: var(--bg);
    font-weight: 800;
    font-size: clamp(2.75rem, 9vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-block: var(--sp-0_75) var(--sp-0_5);
    text-shadow: 0 2px 30px rgba(28, 26, 23, 0.25);
  }
  .hero-split__text {
    color: var(--bg);
    opacity: 0.94;
    max-width: 46ch;
    margin-bottom: var(--sp-1_5);
  }
  .hero-split__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    justify-content: center;
    pointer-events: auto;      /* knoppen blijven klikbaar */
  }
  @media (max-width: 640px) {
    .hero-split--medium .hero-split__pane { min-height: 48vh; }
    .hero-split--large  .hero-split__pane { min-height: 56vh; }
    .hero-split--full   .hero-split__pane { min-height: 70vh; }
    .hero-split__title { font-size: clamp(2.25rem, 13vw, 3.5rem); }
    .hero-split__actions { flex-direction: column; align-items: stretch; width: 100%; max-width: 320px; }
    .hero-split__actions .btn { width: 100%; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Split-hero",
  "settings": [
    {
      "type": "header",
      "content": "Foto"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Afbeelding — mobiel (optioneel)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt-tekst / placeholder",
      "default": "Sfeerbeeld"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optioneel)"
    },
    {
      "type": "header",
      "content": "Tekst over de foto's"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Grote titel",
      "default": "Festival"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtekst"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Positie van de tekst",
      "options": [
        { "value": "bottom", "label": "Onderaan" },
        { "value": "center", "label": "Midden" }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Hoogte",
      "options": [
        { "value": "medium", "label": "Gemiddeld" },
        { "value": "large", "label": "Groot" },
        { "value": "full", "label": "Volledig scherm" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Knop 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Knop 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Split-hero"
    }
  ]
}
{% endschema %}
