{%- comment -%}
  "Seen on #..." — UGC-fotostrook met @-namen en pijltjes (tess v-stijl).
  Hergebruikt de generieke slider ([data-slider]) en de .ig-slider/.slider-btn-stijlen
  uit base.css. Elke tegel toont een foto + @-handle en linkt naar Instagram.
{%- endcomment -%}
{%- assign ig_url = section.settings.instagram_url | default: settings.social_instagram | default: 'https://www.instagram.com/uptodatedamesmode/' -%}

<section class="section section--tight seen-on-section">
  <div class="container container--wide">
    <div class="section-head section-head--center reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-head__title seen-on-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="ig-slider reveal" data-slider>
      <button class="slider-btn slider-btn--prev" type="button" data-slider-prev aria-label="Vorige" hidden>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
      </button>

      <ul class="ig-slider__track" data-slider-track>
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- assign tile_link = block.settings.link | default: ig_url -%}
            <li class="ig-tile seen-tile" {{ block.shopify_attributes }}>
              <a href="{{ tile_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ block.settings.handle | default: 'Bekijk op Instagram' | escape }}">
                {%- if block.settings.image != blank -%}
                  <figure class="media media--square">
                    {{ block.settings.image | image_url: width: 520 | image_tag: loading: 'lazy', alt: block.settings.handle, widths: '260, 360, 520', sizes: '(max-width: 749px) 62vw, 20vw' }}
                  </figure>
                {%- else -%}
                  <div class="media media--square" data-label="{{ block.settings.handle | default: '@uptodatedamesmode' | escape }}"></div>
                {%- endif -%}
                <span class="ig-tile__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
                </span>
                {%- if block.settings.handle != blank -%}
                  <span class="seen-tile__handle">{{ block.settings.handle }}</span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- assign demo_handles = '@noahcelik,@kickiedeklijn,@manushik,@frederiquejosephin,@sennaglaser' | split: ',' -%}
          {%- for handle in demo_handles -%}
            <li class="ig-tile seen-tile">
              <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" aria-label="Bekijk op Instagram">
                <div class="media media--square" data-label="{{ handle }}"></div>
                <span class="ig-tile__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
                </span>
                <span class="seen-tile__handle">{{ handle }}</span>
              </a>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      <button class="slider-btn slider-btn--next" type="button" data-slider-next aria-label="Volgende">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="9 18 15 12 9 6" /></svg>
      </button>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="ig-cta reveal">
        <a class="btn btn--outline" href="{{ ig_url }}" target="_blank" rel="noopener noreferrer">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .seen-on-title { text-transform: uppercase; letter-spacing: 0.06em; }
  .seen-tile a { position: relative; display: block; overflow: hidden; }
  .seen-tile__handle {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    width: 100%;
    padding: 1.4rem 0.9rem 0.7rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--bg);
    background: linear-gradient(180deg, transparent, rgba(28, 26, 23, 0.55));
    pointer-events: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "Seen on (Instagram)",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Kop",
      "default": "Seen on #uptodatedamesmode"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtekst"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram-link (leeg = uit instellingen)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knoplabel (leeg = geen knop)",
      "default": "Volg @uptodatedamesmode"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Foto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "@-naam",
          "default": "@uptodatedamesmode"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optioneel, leeg = Instagram)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seen on (Instagram)",
      "blocks": [
        { "type": "post", "settings": { "handle": "@uptodatedamesmode" } },
        { "type": "post", "settings": { "handle": "@uptodatedamesmode" } },
        { "type": "post", "settings": { "handle": "@uptodatedamesmode" } },
        { "type": "post", "settings": { "handle": "@uptodatedamesmode" } },
        { "type": "post", "settings": { "handle": "@uptodatedamesmode" } }
      ]
    }
  ]
}
{% endschema %}
