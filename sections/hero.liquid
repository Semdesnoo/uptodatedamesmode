<section class="hero">
  {%- if section.settings.image != blank -%}
    {%- assign hero_img = section.settings.image | image_url: width: 2400 -%}
    {%- if section.settings.image_mobile != blank -%}{%- assign hero_img_m = section.settings.image_mobile | image_url: width: 1200 -%}{%- else -%}{%- assign hero_img_m = hero_img -%}{%- endif -%}
    <div class="media media--wide hero__bg" role="img" aria-label="{{ section.settings.heading | default: shop.name | escape }}" style="--hero-bg: url('{{ hero_img }}'); --hero-bg-mobile: url('{{ hero_img_m }}');"></div>
  {%- else -%}
    <div class="media media--wide" data-label="{{ section.settings.placeholder_label | escape }}" role="img" aria-label="{{ section.settings.image_alt | escape }}"></div>
  {%- endif -%}
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <div class="container container--wide">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow reveal">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <h1 class="hero__title reveal" data-delay="1">
          {%- if section.settings.heading != blank -%}<span class="hero__title-main">{{ section.settings.heading }}</span>{%- endif -%}
          {%- if section.settings.subheading != blank -%}<span class="hero__title-accent">{{ section.settings.subheading }}</span>{%- endif -%}
        </h1>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="lead hero__text reveal" data-delay="2">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
        <div class="hero__actions reveal" data-delay="3">
          {%- if section.settings.button_1_label != blank -%}
            <a class="btn btn--light" href="{{ section.settings.button_1_link | default: '#' }}">{{ section.settings.button_1_label }}</a>
          {%- endif -%}
          {%- if section.settings.button_2_label != blank -%}
            <a class="btn btn--outline-light" href="{{ section.settings.button_2_link | default: '#' }}">{{ section.settings.button_2_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Achtergrondafbeelding"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero-afbeelding — mobiel (optioneel)",
      "info": "Staande foto voor mobiel. Leeg = de desktopfoto wordt gebruikt."
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "Tekst op placeholder (zonder afbeelding)",
      "default": "Hero · sfeerbeeld lente/zomer"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt-tekst placeholder",
      "default": "Vrouw in linnen zomeroutfit in zacht daglicht"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop",
      "default": "Nieuw seizoen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Kop (groot, vet)",
      "default": "Bij Up To Date Damesmode"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subkop (kleiner, cursief)",
      "default": "de nieuwste collectie"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtekst",
      "default": ""
    },
    {
      "type": "header",
      "content": "Knop 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Label",
      "default": "Shop de collectie"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Knop 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
