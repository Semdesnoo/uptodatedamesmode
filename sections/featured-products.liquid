<section class="section{% if section.settings.alt_background %} section--alt{% endif %}">
  <div class="container container--wide">
    {%- if section.settings.head_layout == 'between' -%}
      <div class="section-head section-head--between reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2 class="section-head__title">{{ section.settings.heading }}</h2>{%- endif -%}
        </div>
        {%- if section.settings.link_label != blank -%}
          <a class="btn--ghost" href="{{ section.settings.link_url | default: '#' }}">{{ section.settings.link_label }}</a>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="section-head section-head--center reveal">
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="section-head__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subtext != blank -%}<p>{{ section.settings.subtext }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="grid grid--4">
      {%- if section.settings.collection != blank and section.settings.collection.products_count > 0 -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_limit) -%}
          <article class="product-card reveal"{% if forloop.index0 > 0 %} data-delay="{{ forloop.index0 | modulo: 4 }}"{% endif %}>
            <a class="product-card__media-wrap" href="#">
              <div class="media media--portrait" data-label="Voorbeeldproduct"></div>
            </a>
            <p class="product-card__cat">Categorie</p>
            <h3 class="product-card__name"><a href="#">Voorbeeldproduct</a></h3>
            <p class="product-card__price">€0,00</p>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Aantal producten",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "alt_background",
      "label": "Afwijkende achtergrond (section--alt)",
      "default": true
    },
    {
      "type": "select",
      "id": "head_layout",
      "label": "Kop-uitlijning",
      "options": [
        { "value": "between", "label": "Links met knop rechts" },
        { "value": "center", "label": "Gecentreerd" }
      ],
      "default": "between"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop",
      "default": "Vers uit het atelier"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Kop",
      "default": "Nieuw binnen"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtekst (alleen bij gecentreerde kop)"
    },
    {
      "type": "header",
      "content": "Knop (alleen bij 'Links met knop rechts')"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Knoplabel",
      "default": "Bekijk alles"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Knoplink"
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
