{%- comment -%}
  Pagina "Algemene voorwaarden" — bewerkbaar via de Thema-editor.
  De tekst komt uit section.settings (eyebrow/titel/datum/intro) en section.blocks
  (genummerde artikelen: kop + richtext). Het pagina-eigen CSS uit de blauwdruk
  (algemene-voorwaarden.html) staat hieronder in een {% style %}-blok; dit staat
  NIET in base.css. Uitstraling en klassenamen zijn exact behouden.
{%- endcomment -%}

{% style %}
  /* Pagina-header (gecentreerd) */
  .page-header {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) 0;
    text-align: center;
  }
  .page-header__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-top: var(--sp-0_75);
  }
  .page-header__meta {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: var(--sp-1);
  }

  /* Leeskolom: één smalle, rustige kolom voor de juridische tekst */
  .legal {
    max-width: 760px;
    margin-inline: auto;
  }
  .legal__lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    padding-bottom: var(--sp-2);
    margin-bottom: var(--sp-2);
    border-bottom: var(--border);
  }

  /* Genummerde artikelen */
  .legal-article + .legal-article {
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  .legal-article h2 {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    margin-bottom: var(--sp-1);
    scroll-margin-top: 96px;
  }
  .legal-article h3 {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin-top: var(--sp-1_5);
    margin-bottom: var(--sp-0_5);
  }

  /* Alinea's & lijsten: ruime regelafstand, prettig leesbaar */
  .legal p {
    color: var(--ink-soft);
    margin-bottom: var(--sp-1);
  }
  .legal p:last-child { margin-bottom: 0; }
  .legal ul,
  .legal ol {
    list-style: revert;
    padding-left: 1.4rem;
    margin-bottom: var(--sp-1);
    color: var(--ink-soft);
  }
  .legal li { margin-bottom: 0.4rem; }
  .legal li:last-child { margin-bottom: 0; }
  .legal address {
    font-style: normal;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  /* Afbeelding-blok */
  .legal-figure {
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  .legal-figure img {
    display: block;
    width: 100%;
    height: auto;
    border: var(--border);
  }
  .legal-figure figcaption {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: var(--sp-0_75);
    text-align: center;
  }

  /* Slot-/contactblok onderaan de tekst */
  .legal__note {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--bg-alt);
    border: var(--border);
  }
  .legal__note p { margin-bottom: var(--sp-0_5); }
  .legal__note p:last-child { margin-bottom: 0; }
{% endstyle %}

<!-- BREADCRUMB -->
<div class="container">
  <nav class="breadcrumb" aria-label="Kruimelpad">
    <ul>
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><span aria-current="page">{{ page.title | default: 'Algemene voorwaarden' }}</span></li>
    </ul>
  </nav>
</div>

<!-- PAGINA-HEADER: eyebrow + titel + laatst bijgewerkt -->
<section class="page-header">
  <div class="container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow reveal">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="page-header__title reveal" data-delay="1">{{ page.title | default: 'Algemene voorwaarden' }}</h1>
    {%- if section.settings.meta != blank -%}
      <p class="page-header__meta reveal" data-delay="2">{{ section.settings.meta }}</p>
    {%- endif -%}
  </div>
</section>

<!-- LEESKOLOM: juridische tekst in genummerde artikelen -->
<section class="section section--tight">
  <div class="container">
    <div class="legal reveal">

      {%- if section.settings.intro != blank -%}
        <div class="legal__lead">{{ section.settings.intro }}</div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'article' -%}
            <article class="legal-article" {{ block.shopify_attributes }}>
              <h2>
                {%- if block.settings.number != blank -%}{{ block.settings.number }} {% endif -%}
                {{ block.settings.heading }}
              </h2>
              {{ block.settings.content }}
            </article>

          {%- when 'image' -%}
            {%- if block.settings.image != blank -%}
              <figure class="legal-figure" {{ block.shopify_attributes }}>
                {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '400,800,1200,1400', sizes: '(max-width: 900px) 100vw, 760px' }}
                {%- if block.settings.caption != blank -%}
                  <figcaption>{{ block.settings.caption }}</figcaption>
                {%- endif -%}
              </figure>
            {%- endif -%}

          {%- when 'note' -%}
            <div class="legal__note" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>

        {%- endcase -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Algemene voorwaarden",
  "tag": "section",
  "max_blocks": 50,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkop (eyebrow)",
      "default": "Juridisch"
    },
    {
      "type": "text",
      "id": "meta",
      "label": "Laatst bijgewerkt",
      "default": "Laatst bijgewerkt: 22 juni 2026"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introductietekst (lead)",
      "info": "Inleidende paragraaf bovenaan de leeskolom."
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Artikel",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Nummer",
          "info": "Bijv. 1. — laat leeg om te verbergen."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Kop"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Inhoud",
          "info": "Ondersteunt <p>, <br>, <strong>, <em>, <ul>, <ol>, <li> en <a>. Geen tabellen."
        }
      ]
    },
    {
      "type": "image",
      "name": "Afbeelding",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Afbeelding"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Onderschrift (optioneel)"
        }
      ]
    },
    {
      "type": "note",
      "name": "Slot-/contactblok",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Inhoud (in gemarkeerd blok)"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Algemene voorwaarden" }
  ]
}
{% endschema %}
