<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1C1A17">
  <script>document.documentElement.classList.add('js');</script>

  {%- comment -%} Snellere verbinding met Shopify-CDN en font-CDN's (zo vroeg mogelijk) {%- endcomment -%}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.shopify.com">

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%231C1A17'/%3E%3Ctext x='16' y='22' font-family='Georgia,serif' font-size='18' fill='%23FAF8F4' text-anchor='middle'%3EU%3C/text%3E%3C/svg%3E">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; Pagina {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%} Fonts: vroege verbinding + niet render-blocking laden, met font-display: swap (geen onzichtbare tekst) {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link rel="dns-prefetch" href="https://fonts.gstatic.com">

  {%- assign google_fonts_url = 'https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Jost:wght@300;400;500&display=swap' -%}
  <link rel="preload" as="style" href="{{ google_fonts_url }}">
  <link rel="stylesheet" href="{{ google_fonts_url }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ google_fonts_url }}"></noscript>

  {%- comment -%} Hoofd-CSS: vroeg laten ophalen en niet-blokkerend renderen {%- endcomment -%}
  <link rel="preload" as="style" href="{{ 'base.css' | asset_url }}">
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body class="template-{{ request.page_type | handle }}">
  <a class="skip-link" href="#main">Direct naar inhoud</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- comment -%} Zwevende WhatsApp-knop rechtsonder {%- endcomment -%}
  {%- if settings.company_whatsapp != blank -%}
    {%- assign wa_num = settings.company_whatsapp | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' -%}
    <a class="whatsapp-fab" href="https://wa.me/{{ wa_num }}" target="_blank" rel="noopener noreferrer" aria-label="Stuur ons een WhatsApp-bericht">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.8 14.01c-.25.7-1.44 1.33-1.99 1.36-.53.05-1.02.24-3.42-.71-2.88-1.14-4.71-4.09-4.85-4.28-.14-.19-1.16-1.54-1.16-2.94s.73-2.09.99-2.37c.25-.28.55-.35.73-.35.18 0 .37 0 .53.01.17.01.4-.06.62.48.25.6.85 2.07.92 2.22.07.15.12.32.02.51-.09.19-.14.31-.28.48-.14.17-.29.37-.42.5-.14.14-.28.29-.12.56.16.28.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.21 1.37.28.14.44.12.6-.07.16-.19.69-.81.87-1.08.18-.28.37-.23.62-.14.25.09 1.6.75 1.87.89.28.14.46.21.53.33.07.11.07.66-.18 1.36z"/></svg>
    </a>
  {%- endif -%}

  {%- comment -%} 10% kortings-popup — verschijnt na 10 seconden (max. 1x per week per bezoeker) {%- endcomment -%}
  <div class="promo-modal" data-promo-modal hidden>
    <div class="promo-modal__overlay" data-promo-close></div>
    <div class="promo-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="promo-modal-title">
      <button class="promo-modal__close" type="button" data-promo-close aria-label="Sluiten">&times;</button>
      <div class="promo-modal__header">
        <p class="promo-modal__eyebrow">Welkom bij {{ shop.name }}</p>
        <p class="promo-modal__pct">10%</p>
        <h2 class="promo-modal__title" id="promo-modal-title">korting op je eerste bestelling</h2>
      </div>
      <div class="promo-modal__body">
        <p class="promo-modal__text">Meld je aan voor onze nieuwsbrief en ontvang als eerste onze nieuwste collecties, styling-tips én meteen 10% korting.</p>
        {%- form 'customer', class: 'promo-modal__form' -%}
          <input type="hidden" name="contact[tags]" value="nieuwsbrief, 10korting-popup">
          <label class="visually-hidden" for="promo-email">E-mailadres</label>
          <input id="promo-email" type="email" name="contact[email]" placeholder="Je e-mailadres" required>
          <button type="submit" class="btn">Ontvang 10% korting</button>
        {%- endform -%}
        <p class="promo-modal__done" data-promo-done hidden>Gelukt! Gebruik code <strong>WELKOM10</strong> bij het afrekenen voor 10% korting.</p>
        <button class="promo-modal__dismiss" type="button" data-promo-close>Nee bedankt, misschien later</button>
      </div>
    </div>
  </div>

  {%- comment -%} Toon afbeeldingen pas zacht zodra ze VOLLEDIG geladen zijn (placeholder tijdens laden). Zelfstandig + met vangnet, zodat foto's nooit onzichtbaar blijven. {%- endcomment -%}
  <script>
    (function () {
      var SEL = ".media > img, .media > picture > img, .about-hero__media img, .team-grid img, .product-gallery__main img, .product-gallery__thumb img";
      function show(img) { img.classList.add("is-loaded"); }
      function run() {
        document.querySelectorAll(SEL).forEach(function (img) {
          if (img.complete && img.naturalWidth > 0) { show(img); }
          else {
            img.addEventListener("load", function () { show(img); }, { once: true });
            img.addEventListener("error", function () { show(img); }, { once: true });
          }
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run);
      } else { run(); }
      /* Vangnet: zodra de pagina volledig geladen is, sowieso elke foto tonen. */
      window.addEventListener("load", function () {
        document.querySelectorAll(SEL).forEach(show);
      });
    })();
  </script>

  <script src="{{ 'global.js' | asset_url }}" defer></script>
</body>
</html>
